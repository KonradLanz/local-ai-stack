# local-ai-stack — environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# ---------------------------------------------------------------------------
# Model backend — choose ONE
# ---------------------------------------------------------------------------

# Option A: Ollama (recommended, installed by install.sh)
# OLLAMA_MODEL is the model name as it appears in `ollama list`
OLLAMA_MODEL=llama3.1:8b

# Option B: LM Studio (if you prefer to keep using LM Studio as backend)
# Uncomment and set the base URL of your LM Studio local server
# LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1

# ---------------------------------------------------------------------------
# Perplexity Search Bridge (optional)
# ---------------------------------------------------------------------------
# Get your key at https://www.perplexity.ai/api-platform
# Leave empty to disable the Perplexity tool.
PERPLEXITY_API_KEY=

# Perplexity model to use for search queries
# Options: sonar, sonar-pro, sonar-deep-research
PERPLEXITY_MODEL=sonar

# ---------------------------------------------------------------------------
# IPR Privacy Filter
# ---------------------------------------------------------------------------
# Enable outgoing query screening before any public AI API call
IPR_FILTER_ENABLED=true

# Model used for classification: "local" = use Ollama, or specify a model name
IPR_FILTER_MODEL=local

# Path to IPR policy config (relative to repo root)
IPR_POLICY_CONFIG=config/ipr_policy.yaml

# Sensitivity threshold: low / medium / high
# high = block more aggressively
IPR_SENSITIVITY=medium

# ---------------------------------------------------------------------------
# Open WebUI
# ---------------------------------------------------------------------------
WEBUI_SECRET_KEY=change-me-to-a-random-string
